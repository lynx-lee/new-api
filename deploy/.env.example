# New-API Docker Compose Environment Configuration
# Copy this file to .env and modify values before deploying: cp deploy/.env.example .env
# NEVER commit .env to version control!

# ---- Application ----
NEW_API_PORT=3000
METRICS_PORT=9090
TZ=Asia/Shanghai

# ---- Database (PostgreSQL / MySQL) ----
# Choose one: postgres or mysql (set via docker-compose --profile <type>)
DB_TYPE=postgres
DB_USER=root
DB_PASSWORD=CHANGE-ME-STRONG-PASSWORD    # ⚠️ MUST CHANGE!
DB_NAME=new-api

# PostgreSQL
POSTGRES_PORT=5432
# MySQL
MYSQL_PORT=3306

# DSN Override (if set, ignores DB_* variables above)
# SQL_DSN=postgresql://root:password@host:5432/new-api?sslmode=disable

# ---- Redis ----
REDIS_PASSWORD=CHANGE-ME-REDIS-PASSWORD   # ⚠️ MUST CHANGE!

# ---- Security ----
# Generate with: openssl rand -hex 32
SESSION_SECRET=
CRYPTO_SECRET=

# ---- Performance ----
STREAMING_TIMEOUT=300
RELAY_TIMEOUT=0
RELAY_MAX_IDLE_CONNS=500
RELAY_MAX_IDLE_CONNS_PER_HOST=100
SYNC_FREQUENCY=60

# ---- Feature Flags ----
DEBUG=false
ENABLE_PPROF=false

# ---- Monitoring ----
METRICS_ENABLED=true
METRICS_PATH=/metrics

# OpenTelemetry Tracing (optional)
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector:4317

# Canary Release
CANARY_ENABLED=false

# ---- Resource Limits (docker-compose) ----
NEW_API_CPU_LIMIT=2
NEW_API_MEM_LIMIT=1GiB
NEW_API_CPU_RESERVATION=0.2
NEW_API_MEM_RESERVATION=256MiB
